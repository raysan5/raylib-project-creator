{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build debug",
            "type": "process",
            "command": "make",
            "windows": {
                "args": [
                    "RAYLIB_SRC_PATH=C:/raylib/raylib/src",
                    "PLATFORM=PLATFORM_DESKTOP",
                    "BUILD_MODE=DEBUG",
                    "PROJECT_NAME=rpc",
                    "-B"
                ],
            },
            "linux": {
                "args": [
                    "PLATFORM=PLATFORM_DESKTOP",
                    "BUILD_MODE=DEBUG",
                    "PROJECT_NAME=rpc",
                    "-B"
                ],
            },
            "osx": {
                "args": [
                    "RAYLIB_SRC_PATH=../../../raylib/src",
                    "PLATFORM=PLATFORM_DESKTOP",
                    "BUILD_MODE=DEBUG",
                    "PROJECT_NAME=rpc",
                    "-B"
                ],
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "options": {
                "cwd": "${workspaceFolder}/../../src"
            },
        },
        {
            "label": "build release",
            "type": "process",
            "command": "make",
            "windows": {
                "args": [
                    "RAYLIB_SRC_PATH=C:/raylib/raylib/src",
                    "PLATFORM=PLATFORM_DESKTOP",
                    "BUILD_MODE=RELEASE",
                    "PROJECT_NAME=rpc",
                    "-B"
                ],
            },
            "linux": {
                "args": [
                    "PLATFORM=PLATFORM_DESKTOP",
                    "BUILD_MODE=RELEASE",
                    "PROJECT_NAME=rpc",
                    "-B"
                ],
            },
            "osx": {
                "args": [
                    "RAYLIB_SRC_PATH=../../../raylib/src",
                    "PLATFORM=PLATFORM_DESKTOP",
                    "BUILD_MODE=RELEASE",
                    "PROJECT_NAME=rpc",
                    "-B"
                ],
            },
            "group": "build",
            "options": {
                "cwd": "${workspaceFolder}/../../src"
            },
        }
    ]
}